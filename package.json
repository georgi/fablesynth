{
  "name": "fablesynth",
  "version": "1.0.0",
  "description": "A Serum-style wavetable synthesizer that runs entirely in the browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "clips:generate": "node scripts/generate-clip-library.mjs",
    "clips:check": "node scripts/generate-clip-library.mjs --check",
    "standalone:build": "cmake --build juce/build --target FableSynth_Standalone FableDrum_Standalone FableBass_Standalone FableSeq_Standalone -j4",
    "vst:install": "bash scripts/install-vst.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.9"
  }
}
